rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if ownsUserDoc(userId)
        && request.resource.data.role in ['seller', 'driver'];
      allow update: if ownsUserDoc(userId)
        && resource.data.role == request.resource.data.role;
    }

    match /conversations/{conversationId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.participantIds;
      allow create, update: if signedIn()
        && request.auth.uid in request.resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

    match /payments/{paymentId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.sellerId || request.auth.uid == resource.data.driverId);
      allow create: if signedIn()
        && (request.auth.uid == request.resource.data.sellerId || request.auth.uid == request.resource.data.driverId);
    }

    match /calls/{callId} {
      allow read, update, delete: if signedIn()
        && request.auth.uid in resource.data.participantIds;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds;

      match /{candidateCollection}/{candidateId} {
        allow read, create: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participantIds;
      }
    }
  }
}
